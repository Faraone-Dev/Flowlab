# ─── FLOWLAB runtime configuration ──────────────────────────────────


# ─── Mmap ring buffer (Go ingest → Rust replay IPC) ─────────────────
# Path to the mmap-backed ring file. Producer (Go) and consumer (Rust)
# must agree on path and capacity.
FLOWLAB_RING_PATH=/var/lib/flowlab/ring.flowring
# Ring payload capacity in bytes. MUST be a power of two.
# 16 MiB ≈ 419k events at 40 B/event.
FLOWLAB_RING_CAPACITY=16777216

# ─── Write-ahead log (durability + bit-exact replay) ────────────────
# Directory where wal-{NNNN}.log segments are stored.
FLOWLAB_WAL_DIR=/var/lib/flowlab/wal
# Segment rollover size in bytes. Default 64 MiB.
FLOWLAB_WAL_SEGMENT_SIZE=67108864

# ─── MoldUDP64 multicast feed ───────────────────────────────────────
# Local bind address (interface IP for UDP socket).
FLOWLAB_UDP_BIND=0.0.0.0:30001
# Multicast group to join.
FLOWLAB_UDP_GROUP=233.54.12.1:30001
# Outgoing interface for IGMP join (empty = OS default).
FLOWLAB_UDP_INTERFACE=
# Read timeout in milliseconds (0 = blocking forever).
FLOWLAB_UDP_TIMEOUT_MS=200
# Maximum out-of-order forward buffer (in messages).
FLOWLAB_UDP_MAX_FORWARD_BUFFER=4096

# ─── Circuit breaker (risk gate) ────────────────────────────────────
FLOWLAB_BREAKER_MAX_ORDERS_PER_SEC=5000
FLOWLAB_BREAKER_MAX_POSITION=10000
FLOWLAB_BREAKER_MAX_DAILY_LOSS_TICKS=5000000000
FLOWLAB_BREAKER_MAX_OTR=100.0
FLOWLAB_BREAKER_OTR_WARMUP=100
FLOWLAB_BREAKER_GAP_THRESHOLD=16
FLOWLAB_BREAKER_GAP_WINDOW_SECS=60

# ─── Control plane / metrics (Go api/) ──────────────────────────────
FLOWLAB_API_BIND=0.0.0.0:8080
FLOWLAB_METRICS_PATH=/metrics

# ─── Logging ────────────────────────────────────────────────────────
# tracing-subscriber EnvFilter syntax.
RUST_LOG=info,flowlab_replay=debug,flowlab_flow=debug
